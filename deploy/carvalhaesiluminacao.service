[Unit]
Description=Carvalhaes Iluminacao Site
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/bruno/Documentos/Github/carvalhaesiluminacao
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
User=bruno

[Install]
WantedBy=multi-user.target
